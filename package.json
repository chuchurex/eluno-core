{
  "name": "@eluno/core",
  "version": "2.0.0",
  "type": "module",
  "description": "Shared build system, styles, and fonts for eluno book projects",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/chuchurex/eluno-core.git"
  },
